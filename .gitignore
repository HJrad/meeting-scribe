# ── Secrets ───────────────────────────────────────────────────────────────────
# Never commit API keys. Track only *.example templates.
.env
.env.*
!.env.example

# ── Private data (recordings, real configs, biometric voice clips) ─────────────
# Real meeting recordings — never publish.
meetings/*
!meetings/.gitkeep

# Real meeting manifest holds names, customers, and business context.
# Track config/meetings.example.yaml instead.
config/meetings.yaml
config/meetings*.yaml
!config/meetings.example.yaml

# Local defaults / partner branding hold real org names + logos. Track examples.
config/config.yaml
!config/config.example.yaml
config/partners.yaml
!config/partners.example.yaml

# Brand logos are third-party trademarks — keep them out of the public repo.
assets/brand/logos/

# Participant voice reference clips (biometric data).
voice_samples/*
!voice_samples/.gitkeep

# ── Generated by pipeline ─────────────────────────────────────────────────────
.cache/
output/

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ── Local tooling state ───────────────────────────────────────────────────────
.claude/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
._*
