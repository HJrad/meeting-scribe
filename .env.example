# Copy to .env and fill in real values. Never commit .env.

# Used for summary generation (chat completions).
OPENAI_API_KEY=sk-your-openai-key-here

# Used by pyannote for speaker diarization. Get one at https://huggingface.co/settings/tokens
# You must also accept the model terms for the gated pyannote models.
HF_TOKEN=hf_your-huggingface-token-here
